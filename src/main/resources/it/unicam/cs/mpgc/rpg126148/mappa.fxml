<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg126148.controller.MappaController"
            style="-fx-background-color: #1a1a2e;"
            maxWidth="Infinity"
            maxHeight="Infinity">

    <!-- TOP: stats giocatore -->
    <top>
        <HBox style="-fx-background-color: #16213e; -fx-padding: 10 20;"
              spacing="30" alignment="CENTER_LEFT">
            <Label fx:id="labelNome"
                   text="Giocatore"
                   style="-fx-text-fill: #e94560; -fx-font-size: 14; -fx-font-weight: bold;"/>
            <Label fx:id="labelHP"
                   text="HP: 100/100"
                   style="-fx-text-fill: #4ecca3; -fx-font-size: 13;"/>
            <Label fx:id="labelEnergia"
                   text="EN: 100/100"
                   style="-fx-text-fill: #f5a623; -fx-font-size: 13;"/>
            <Label fx:id="labelFrammenti"
                   text="Frammenti: F:0 C:0 O:0"
                   style="-fx-text-fill: #a8a8b3; -fx-font-size: 13;"/>
            <Label fx:id="labelStanza"
                   text="Stanza: -"
                   style="-fx-text-fill: #a8a8b3; -fx-font-size: 13;"/>
        </HBox>
    </top>

    <!-- CENTER: griglia mappa -->
    <center>
        <GridPane fx:id="gridMappa"
                  style="-fx-padding: 20;"
                  alignment="CENTER"
                  hgap="2" vgap="2"/>
    </center>

    <!-- RIGHT: log eventi -->
    <right>
        <VBox style="-fx-background-color: #16213e; -fx-padding: 15;"
              spacing="10" prefWidth="220">

            <Label text="LOG"
                   style="-fx-text-fill: #e94560; -fx-font-weight: bold; -fx-font-size: 13;"/>

            <TextArea fx:id="logArea"
                      editable="false"
                      wrapText="true"
                      prefHeight="350"
                      style="-fx-background-color: #0f3460; -fx-text-fill: #a8a8b3;
                         -fx-font-size: 11; -fx-border-color: #e94560;"/>

            <Label text="LEGENDA"
                   style="-fx-text-fill: #e94560; -fx-font-weight: bold; -fx-font-size: 12;"/>

            <VBox spacing="4">
                <Label text=" @ = Tu"
                       style="-fx-text-fill: #4ecca3; -fx-font-size: 11;"/>
                <Label text="N = Nemico"
                       style="-fx-text-fill: #e94560; -fx-font-size: 11;"/>
                <Label text="C = Cassa"
                       style="-fx-text-fill: #4ecca3; -fx-font-size: 11;"/>
                <Label text="O = Ingresso stanza"
                       style="-fx-text-fill: #f5a623; -fx-font-size: 11;"/>
                <Label text="+ = Parete stanza"
                       style="-fx-text-fill: #4a90d9; -fx-font-size: 11;"/>
                <Label text="? = Interno nascosto"
                       style="-fx-text-fill: #8888aa; -fx-font-size: 11;"/>
                <Label text="I = Inventario"
                       style="-fx-text-fill: #f5a623; -fx-font-size: 11;"/>
                <Label text="P = Salvataggio rapido"
                       style="-fx-text-fill: #a8a8b3; -fx-font-size: 11;"/>
            </VBox>

            <Label text="COMANDI"
                   style="-fx-text-fill: #e94560; -fx-font-weight: bold; -fx-font-size: 12;"/>
            <Label text="W A S D = Muoviti"
                   style="-fx-text-fill: #a8a8b3; -fx-font-size: 11;"/>

            <Button text="Salva ed Esci"
                    onAction="#salvaEsci"
                    prefWidth="190"
                    style="-fx-background-color: #e94560; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 6;
                       -fx-cursor: hand; -fx-padding: 8 15;"/>


        </VBox>
    </right>


</BorderPane>