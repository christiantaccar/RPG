<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg126148.controller.CreaPersonaggioController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Text text="CREA IL TUO PERSONAGGIO"
          style="-fx-fill: #e94560; -fx-font-size: 28; -fx-font-weight: bold;"/>

    <Text text="Scegli il nome del tuo stregone"
          style="-fx-fill: #a8a8b3; -fx-font-size: 14;"/>

    <TextField fx:id="campoNome"
               promptText="Inserisci il nome..."
               maxWidth="300"
               style="-fx-background-color: #16213e; -fx-text-fill: white;
                      -fx-border-color: #e94560; -fx-border-radius: 6;
                      -fx-background-radius: 6; -fx-font-size: 14;
                      -fx-padding: 8;"/>

    <Label fx:id="labelErrore"
           text=""
           style="-fx-text-fill: #e94560; -fx-font-size: 12;"/>

    <Button fx:id="btnConferma"
            text="Inizia l'avventura"
            onAction="#conferma"
            prefWidth="200"
            style="-fx-background-color: #e94560; -fx-text-fill: white;
                   -fx-font-size: 14; -fx-font-weight: bold;
                   -fx-background-radius: 8; -fx-cursor: hand;"/>

    <Button text="Torna al menu"
            onAction="#tornaMenu"
            prefWidth="200"
            style="-fx-background-color: transparent; -fx-text-fill: #a8a8b3;
                   -fx-font-size: 12; -fx-cursor: hand;"/>

</VBox>